<odoo>
    <data noupdate="1">
        <record id="ir_cron_generate_monthly_plans" model="ir.cron">
            <field name="name">Generate Monthly and Individual Work Plans</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_calendar_workplan_plan"/>
            <field name="code">model.generate_next_month_plans()</field>
            <field name="nextcall" eval="(DateTime.now().replace(day=25)).strftime('%Y-%m-%d 00:00:00')"/>
            <field name="priority" eval="100"/>
        </record>
         <!-- Cron para duplicar planes al próximo año -->
        <record id="ir_cron_duplicate_workplans_next_year" model="ir.cron">
            <field name="name">Duplicar planes al próximo año</field>
            <field name="model_id" ref="model_calendar_workplan_plan"/>
            <field name="state">code</field>
            <field name="code">
                <field name="code">
                for plan in model.search([('scope','=','annual')]):
                    plan.duplicate_plan_next_year()
                </field>

            </field>
            <!-- Ejecutar cada 1 de diciembre a las 23:00 -->
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="nextcall">2026-12-01 23:00:00</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>


