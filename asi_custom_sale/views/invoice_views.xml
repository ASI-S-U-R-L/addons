<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_invoice_filter" model="ir.ui.view">
            <field name="name">invoice.filter</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="date" position="attributes">
                    <attribute name="filter_domain">[('invoice_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;', (context_today() + relativedelta(day=1, months=+1)).strftime('%%Y-%%m-%%d'))]</attribute>
                </field>
                <field name="state" position="before">
                    <field name="gestion_state"/>
                </field>
            </field>
        </record>
        <record id="view_invoice_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="gestion_state" readonly="1" attrs="{'invisible': True}"/>     
                    <field name="analytic_accounts_ids" widget="many2many_tags"/>
                </xpath>

                <group id="header_left_group" position="inside">
                    <field name="customer_signer_id" attrs="{'invisible': ['!', ('move_type', 'in', ['out_invoice', 'out_refund'])]}"/>
                </group>
                  <xpath expr="//header" position="inside">
                        <button name="action_set_gestion_state_sent" type="object"
                                string="Enviar al Cliente" 
                                attrs="{'invisible': ['|', ('gestion_state', '=', 'sent_client'), ('state', '!=', 'posted')]}"/>
                        <button name="action_set_gestion_state_received" type="object"
                                string="Marcar Recibida"
                                attrs="{'invisible': ['|', ('state', '!=', 'posted'), ('gestion_state', 'not in', ['none','sent_client'])]}"/>
                        <button name="action_set_gestion_state_archived" type="object"
                                string="Archivar"
                                attrs="{'invisible': ['|', ('state', '!=', 'posted'), ('gestion_state', '!=', 'received')]}"/>
                  </xpath>
            </field>
        </record>


<record id="view_invoice_search_gestion_state" model="ir.ui.view">
    <field name="name">invoice.search.gestion.state</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_account_invoice_filter"/>
    <field name="arch" type="xml">

        <!-- Filtros simples -->
        <xpath expr="//search" position="inside">
            <filter name="current_month" string="Mes actual"
        domain="[
            '&amp;',
            ('invoice_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%%Y-%%m-%%d')),
            ('invoice_date', '&lt;', (context_today() + relativedelta(day=1, months=+1)).strftime('%%Y-%%m-%%d'))
        ]"/>

<filter name="last_month" string="Mes pasado"
        domain="[
            '&amp;',
            ('invoice_date', '&gt;=', (context_today() + relativedelta(day=1, months=-1)).strftime('%%Y-%%m-%%d')),
            ('invoice_date', '&lt;', (context_today() + relativedelta(day=1)).strftime('%%Y-%%m-%%d'))
        ]"/>

            <filter name="gestion_incomplete" string="Incompletas"
                    domain="['&amp;', ('state', '=', 'posted'), ('gestion_state', '!=', 'archived')]"/>
            <filter name="gestion_none" string="Sin gestionar"
                    domain="['&amp;', ('gestion_state','=','none'), ('state', '=', 'posted')]"/>
            <filter name="gestion_sent" string="Enviada al Cliente"
                    domain="['&amp;', ('gestion_state','=','sent_client'), ('state', '=', 'posted')]"/>
            <filter name="gestion_received" string="Recibida"
                    domain="['&amp;', ('gestion_state','=','received'), ('state', '=', 'posted')]"/>
            <filter name="gestion_archived" string="Archivada"
                    domain="['&amp;', ('gestion_state','=','archived'), ('state', '=', 'posted')]"/>
        </xpath>

        <!-- Agrupar por -->
        <xpath expr="//group[@expand='0']" position="inside">
            <filter name="group_gestion_state"
                    string="Estado de Gestión"
                    context="{'group_by': 'gestion_state'}"/>      
            <filter name="group_analytic_accounts"
                    string="Responsable de Factura"
                    context="{'group_by': 'analytic_accounts_ids'}"/>                      
        </xpath>

    </field>
</record>

<record id="action_set_gestion_state_sent_multi" model="ir.ui.view">
    <field name="name">invoice.tree.gestion.state.sent.multi</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_out_invoice_tree"/>
    <field name="arch" type="xml">

        <xpath expr="//tree/header" position="inside">
            <button name="action_set_gestion_state_sent"
                    string="Marcar en el Cliente"
                    type="object"
                    class="btn-success"
                    context="{'from_mass_action': True}"
                    groups="account.group_account_invoice"/>
              <button name="action_set_gestion_state_received"
                            string="Marcar Recibida"
                            type="object"
                            class="btn-success"
                            context="{'from_mass_action': True}"
                            groups="account.group_account_invoice"/>
              <button name="action_set_gestion_state_archived"
                            string="Marcar Archivada"
                            type="object"
                            class="btn-success"
                            context="{'from_mass_action': True}"
                            groups="account.group_account_invoice"/>                
        </xpath>

    </field>
</record>

<record id="view_invoice_tree_gestion_colors" model="ir.ui.view">
    <field name="name">invoice.tree.gestion.colors</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_out_invoice_tree"/>
    <field name="arch" type="xml">

        <xpath expr="//tree" position="attributes">
            <attribute name="decoration-muted">gestion_state == 'none'</attribute>
            <attribute name="decoration-info">gestion_state == 'sent_client'</attribute>
            <attribute name="decoration-warning">gestion_state == 'received'</attribute>
            <attribute name="decoration-success">gestion_state == 'archived'</attribute>
        </xpath>

    </field>
</record>


    </data>
</odoo>